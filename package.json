{
  "name": "spark-room",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently --kill-others-on-fail --names server,client --prefix-colors blue,magenta \"npm run dev:server\" \"npm run dev:client\"",
    "dev:client": "vite --host 127.0.0.1",
    "dev:server": "tsx watch src/server/index.ts",
    "build": "npm run build:client && npm run build:server",
    "build:client": "vite build",
    "build:server": "tsc -p tsconfig.server.json",
    "check": "tsc --noEmit && tsc -p tsconfig.server.json --noEmit",
    "start:server": "node dist/server/index.js",
    "mcp": "tsx src/mcp/index.ts",
    "mcp:dev": "tsx src/mcp/index.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/node": "26.1.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "concurrently": "10.0.3",
    "tsx": "4.23.1",
    "typescript": "7.0.2",
    "vite": "8.1.4"
  },
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=10.0.0"
  }
}
